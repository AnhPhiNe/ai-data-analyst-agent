# FastAPI metadata
APP_NAME=AI Data Analyst Agent
APP_ENV=development

# Optional. Leave API keys empty to run deterministic routing without LLM fallback.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
MAX_PLANNER_VALIDATION_RETRIES=1

# Upload and frontend settings
MAX_UPLOAD_MB=10
MAX_ROWS=100000
MAX_COLUMNS=200
MAX_SESSIONS=25
SESSION_TTL_SECONDS=3600
REQUIRE_SESSION_TOKEN=false
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_WINDOW_SECONDS=60
BACKEND_URL=http://localhost:8000
