# FastAPI metadata
APP_NAME=AI Data Analyst Agent
APP_ENV=development

# Optional. Leave empty to run deterministic routing without Gemini fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Upload and frontend settings
MAX_UPLOAD_MB=10
MAX_ROWS=100000
MAX_COLUMNS=200
MAX_SESSIONS=25
SESSION_TTL_SECONDS=3600
REQUIRE_SESSION_TOKEN=false
BACKEND_URL=http://localhost:8000
